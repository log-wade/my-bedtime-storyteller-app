# Auth.js (NextAuth v5) – use `openssl rand -base64 32` for AUTH_SECRET
AUTH_SECRET=
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Apple: https://developer.apple.com/account/resources/identifiers/list/serviceId
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Get your API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Stripe (https://dashboard.stripe.com/apikeys, https://dashboard.stripe.com/webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Monthly price ID (My Bedtime Storyteller — $9.99/mo, 7-day trial set at checkout)
# Created via Stripe: product "My Bedtime Storyteller" → price price_1T8onuRsxm9dFvTh6smwqBmQ
NEXT_PUBLIC_STRIPE_PRICE_ID=price_1T8onuRsxm9dFvTh6smwqBmQ
# App base URL for Checkout success/cancel redirects (e.g. https://yourapp.com or http://localhost:3000)
NEXT_PUBLIC_APP_URL=
